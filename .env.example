# Optional: direct Postgres connection
SUPABASE_DB_PASSWORD=

# Mapbox (Map overview page)
VITE_MAPBOX_ACCESS_TOKEN=

# Ingest script — path to GIS project root (defaults to parent of site-viewer)
PROJECT_ROOT=
